# Required: Anthropic API key for both orchestrator and verifier subagent.
ANTHROPIC_API_KEY=sk-ant-...

# Required: read-only Postgres URL handed to the postgres MCP container.
# On event day, copy from FED/.env.public's DB_CONNECTION_STRING.
# For local development against the docker-compose Postgres in this repo's
# root, use the local connection (DB is named "hackaton" with user qohash).
READONLY_DATABASE_URL=postgresql://qohash:qohash@host.docker.internal:5434/hackaton

# Optional: override server bind.
HOST=127.0.0.1
PORT=8080
